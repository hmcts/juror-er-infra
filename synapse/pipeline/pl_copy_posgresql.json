												"physicalType": "UTF8"
											},
											"sink": {
												"name": "lname",
												"type": "String",
												"physicalType": "character varying"
											}
										},
										{
											"source": {
												"name": "fname",
												"type": "String",
												"physicalType": "UTF8"
											},
											"sink": {
												"name": "fname",
												"type": "String",
												"physicalType": "character varying"
											}
										},
										{
											"source": {
												"name": "dob",
												"type": "DateTime",
												"physicalType": "DATE"
											},
											"sink": {
												"name": "dob",
												"type": "DateTime",
												"physicalType": "date"
											}
										},
										{
											"source": {
