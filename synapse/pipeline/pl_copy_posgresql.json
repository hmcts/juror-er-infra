												"type": "String",
												"physicalType": "UTF8"
											},
											"sink": {
												"name": "new_marker",
												"type": "String",
												"physicalType": "character varying"
											}
										},
										{
											"source": {
												"name": "title",
												"type": "String",
												"physicalType": "UTF8"
											},
											"sink": {
												"name": "title",
												"type": "String",
												"physicalType": "character varying"
											}
										},
										{
											"source": {
												"name": "lname",
