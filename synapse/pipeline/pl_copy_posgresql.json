			}
		],
		"parameters": {
			"parquet_file": {
				"type": "string",
				"defaultValue": "masked_voters_temp2.parquet"
			},
			"container": {
				"type": "string",
				"defaultValue": "voters-temp-2025"
			},
			"sink_schema": {
				"type": "string",
				"defaultValue": "juror_eric"
			},
			"sink_table": {
				"type": "string",
				"defaultValue": "voters_temp"
			}
